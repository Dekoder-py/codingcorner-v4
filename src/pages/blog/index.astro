---
import "../../styles/globals.css";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
---
<a href="/">Home</a>
<h1>Blog</h1>

<ul>
  {posts.map((post) => (
    <li>
      <a href={`/blog/${post.slug}/`}>
        {post.data.title}
      </a>
    </li>
  ))}
</ul>

